<Window x:Class="CDBurner.View.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CDBurner.View"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        Background="White"
        AllowsTransparency="True">
    <Border CornerRadius="10" Padding="20" Background="White" BorderBrush="#ccc" BorderThickness="1">
        <StackPanel Width="300">

            <TextBlock Text="{Binding Title}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Message}" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="80"
                        Margin="5"
                        Visibility="{Binding IsOkVisible}"
                        Command="{Binding OkCommand}"/>

                <Button Content="Yes"
                        Width="80"
                        Margin="5"
                        Visibility="{Binding IsYesNoVisible}"
                        Command="{Binding YesCommand}"/>

                <Button Content="No"
                        Width="80"
                        Margin="5"
                        Visibility="{Binding IsYesNoVisible}"
                        Command="{Binding NoCommand}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
