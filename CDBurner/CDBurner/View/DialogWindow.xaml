<Window x:Class="CDBurner.View.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CDBurner.View"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Border Padding="20" Background="{DynamicResource WindowBackgroundBrush}" 
            BorderBrush="#ccc" BorderThickness="1" CornerRadius="4">
        <StackPanel Width="300">
            <TextBlock Text="{Binding Title}" 
                       FontSize="24"
                       TextWrapping="Wrap"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Message}"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding Progress}"
                         Visibility="{Binding IsProgressVisible}"
                         Foreground="Green"
                         Height="20"
                         Margin="0,10,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Understand}"
                        Width="Auto"
                        Height="30"
                        Margin="5"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource SecondaryBrush}"
                        BorderThickness="0"
                        Visibility="{Binding IsOkVisible}"
                        Command="{Binding OkCommand}"/>

                <Button Content="{DynamicResource Yes}"
                        Width="80"
                        Height="30"
                        Margin="5"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource SecondaryBrush}"
                        BorderThickness="0"
                        Visibility="{Binding IsYesNoVisible}"
                        Command="{Binding YesCommand}"/>

                <Button Content="{DynamicResource No}"
                        Width="80"
                        Height="30"
                        Margin="5"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White"
                        BorderThickness="1"
                        Visibility="{Binding IsYesNoVisible}"
                        Command="{Binding NoCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
