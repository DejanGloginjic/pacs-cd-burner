<UserControl x:Class="CDBurner.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CDBurner.View"
             xmlns:behavior="clr-namespace:CDBurner.Behavior"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200" Background="{DynamicResource WindowBackgroundBrush}"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Style="{DynamicResource GlobalFontStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Grid.Row="0" 
                Background="{DynamicResource PrimaryBrush}" 
                CornerRadius="12" 
                Padding="20,16"
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border Background="{DynamicResource TextBoxBackgroundBrush}" CornerRadius="8" Padding="4" Height="40">
                        <TextBox Width="320"
                                 md:HintAssist.Hint="{DynamicResource Search}"
                                 Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Height="24"
                                 FontSize="16"
                                 FontWeight="Normal"
                                 VerticalContentAlignment="Center"
                                 Foreground="White"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="12,0"/>
                    </Border>

                    <Button Command="{Binding SearchCommand}"
                            IsDefault="True"
                            Width="32"
                            Height="32"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Background="{DynamicResource HeaderBrush}"
                            BorderThickness="0"
                            Margin="12,0,0,0"
                            ToolTip="{DynamicResource Search}">
                        <md:PackIcon Kind="Search"
                                     Width="22"
                                     Height="22"
                                     Foreground="{DynamicResource ButtonForegroundBrush}"/>
                    </Button>
                    <Button Command="{Binding ResetCommand}"
                            Visibility="{Binding IsResetVisible}"
                            Width="32"
                            Height="32"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Background="{DynamicResource HeaderBrush}"
                            BorderThickness="0"
                            Margin="12,0,0,0"
                            ToolTip="{DynamicResource Reset}">
                        <md:PackIcon Kind="Close"
                                     Width="22"
                                     Height="22"
                                     Foreground="{DynamicResource ButtonForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Grid Margin="0,0,40,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource TextBoxBackgroundBrush}" CornerRadius="8" Padding="4" >
                            <DatePicker Grid.Column="0"
                                        SelectedDate="{Binding DateFrom, Mode=TwoWay}" 
                                        md:HintAssist.Hint="{DynamicResource DateFrom}"
                                        Style="{StaticResource MaterialDesignDatePicker}"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Padding="12,10"
                                        Width="120"
                                        FontSize="14"/>
                        </Border>

                        <Border Background="{DynamicResource TextBoxBackgroundBrush}" CornerRadius="8" Padding="4" Grid.Column="2">
                            <md:TimePicker Grid.Column="2"
                                            SelectedTime="{Binding DateFrom, Mode=TwoWay}"
                                            md:HintAssist.Hint="{DynamicResource TimeFrom}"
                                            Style="{StaticResource MaterialDesignTimePicker}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Padding="8,10"
                                            FontSize="14"
                                            Width="120"
                                            Is24Hours="True"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource TextBoxBackgroundBrush}" CornerRadius="8" Padding="4" >
                            <DatePicker Grid.Column="0"
                                        SelectedDate="{Binding DateTo, Mode=TwoWay}" 
                                        md:HintAssist.Hint="{DynamicResource DateTo}"
                                        Style="{StaticResource MaterialDesignDatePicker}"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Width="120"
                                        Padding="12,10"
                                        FontSize="14"/>
                        </Border>

                        <Border Background="{DynamicResource TextBoxBackgroundBrush}" CornerRadius="8" Padding="4" Grid.Column="2">
                            <md:TimePicker Grid.Column="2"
                                            SelectedTime="{Binding DateTo, Mode=TwoWay}"
                                            md:HintAssist.Hint="{DynamicResource TimeTo}"
                                            Style="{StaticResource MaterialDesignTimePicker}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Padding="8,10"
                                            FontSize="14"
                                            Width="120"
                                            Is24Hours="True"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" 
                Background="{DynamicResource HeaderBrush}" 
                CornerRadius="12,12,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="0.5*" />
                    <ColumnDefinition Width="0.5*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{DynamicResource PatientId}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock Grid.Column="1" 
                           Text="{DynamicResource Patient}"
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock Grid.Column="2" 
                           Text="{DynamicResource PatientSex}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock Grid.Column="3" 
                           Text="{DynamicResource Modality}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock Grid.Column="4" 
                           Text="{DynamicResource Date}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock />
                <TextBlock Grid.Column="5" 
                           Text="{DynamicResource Description}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
                <TextBlock Grid.Column="6" 
                           Text="{DynamicResource Burn}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.95"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Grid.Column="1" 
                Background="{DynamicResource PrimaryBrush}" 
                CornerRadius="0,0,12,12"
                Padding="4">
            <ListView ItemsSource="{Binding Studies}"
                      x:Name="StudiesListView"
                      behavior:ListViewScrollBehavior.ScrollToTop="{Binding CurrentPage}"
                      Cursor="Arrow" 
                      HorizontalContentAlignment="Stretch"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      AlternationCount="2">
                <ListView.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                    </Style>
                </ListView.Resources>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="Padding" Value="16,12"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#FF1E293B"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF475569"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="0.5*" />
                                <ColumnDefinition Width="0.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="0.5*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding PatientId}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Patient}" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="White" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PatientSex}" 
                                       FontSize="14" 
                                       FontWeight="Medium" 
                                       Foreground="White" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Modality}" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="White" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" 
                                       Text="{Binding Date, StringFormat=dd/MM/yyyy   HH:mm}" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="White" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" 
                                       Text="{Binding Description}" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="White" 
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.BurnOnCDCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                        CommandParameter="{Binding}"
                                        Width="36" Height="36"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                        Background="{DynamicResource HeaderBrush}"
                                        BorderThickness="0"
                                        ToolTip="{DynamicResource Burn}">
                                    <md:PackIcon Kind="DiscPlayer" Width="18" Height="18" Foreground="{DynamicResource ButtonForegroundBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="6" Grid.Column="1" 
                Background="{DynamicResource PrimaryBrush}" 
                CornerRadius="12" 
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Command="{Binding PreviousPageCommand}"
                        Width="40"
                        Height="40"
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                        Background="{DynamicResource HeaderBrush}"
                        BorderThickness="0"
                        ToolTip="{DynamicResource PreviousPage}">
                    <md:PackIcon Kind="ArrowLeft"
                                 Width="20"
                                 Height="20"
                                 Foreground="{DynamicResource ButtonForegroundBrush}"/>
                </Button>

                <Border Background="#20FFFFFF" 
                        CornerRadius="8" 
                        Padding="20,10" 
                        Margin="16,0">
                    <TextBlock Text="{Binding PaginationText}" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="14"/>
                </Border>

                <Button Command="{Binding NextPageCommand}"
                        Width="40"
                        Height="40"
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                        Background="{DynamicResource HeaderBrush}"
                        BorderThickness="0"
                        ToolTip="{DynamicResource NextPage}">
                    <md:PackIcon Kind="ArrowRight"
                                 Width="20"
                                 Height="20"
                                 Foreground="{DynamicResource ButtonForegroundBrush}"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>